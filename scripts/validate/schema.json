{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cloud-rosetta.example/schemas/result.json",
  "title": "Comparison Result",
  "description": "比較結果データのスキーマ定義",
  "type": "object",
  "required": ["themeId", "axisId", "providers", "comparedAt", "comparedBy"],
  "additionalProperties": false,
  "properties": {
    "themeId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,62}[a-z0-9]$",
      "description": "比較テーマの一意識別子（英小文字・数字・ハイフン、2-64文字）"
    },
    "axisId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,62}[a-z0-9]$",
      "description": "比較軸の一意識別子（英小文字・数字・ハイフン、2-64文字）"
    },
    "providers": {
      "type": "array",
      "minItems": 2,
      "description": "比較対象プロバイダーのリスト（最低2つ）",
      "items": {
        "type": "object",
        "required": ["name", "serviceName", "summary", "sources"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "プロバイダー名（例: AWS, GCP, Azure）"
          },
          "serviceName": {
            "type": "string",
            "description": "サービス名（例: AWS Lambda, Cloud Functions）"
          },
          "summary": {
            "type": "string",
            "description": "比較結果の要約"
          },
          "details": {
            "type": "string",
            "description": "詳細な比較内容（オプション）"
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "description": "参照元URL（最低1つ、一次情報を含むこと）",
            "items": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    },
    "comparedAt": {
      "type": "string",
      "format": "date-time",
      "description": "比較実施日時（ISO 8601 UTC）"
    },
    "comparedBy": {
      "type": "string",
      "description": "比較実施者（GitHub ユーザー名 or エージェント ID）"
    }
  }
}
